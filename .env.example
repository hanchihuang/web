# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Django 密钥（生产环境必须更改）
SECRET_KEY=your-secret-key-here

# 数据库连接 URL（Railway 会自动注入）
DATABASE_URL=postgresql://user:password@host:port/dbname

# 允许的主机（逗号分隔）
ALLOWED_HOSTS=.railway.app,yourdomain.com

# 调试模式（生产环境设为 False）
DEBUG=False

# TTS：默认值足够覆盖当前 2200 字整段直出，避免单段被硬截断在约 2 分钟
QWEN_TTS_MAX_NEW_TOKENS=32768

# Massive Flat Files S3 转接配置
# 获取方式：https://massive.com → Account → API Keys
# S3 Endpoint: https://files.massive.com，Bucket: flatfiles
# 支持 stock / options 数据：us_stocks_sip/ 和 us_options_opra/
MASSIVE_S3_ENDPOINT=https://files.massive.com
MASSIVE_S3_BUCKET=flatfiles
MASSIVE_S3_REGION=us-east-1
MASSIVE_S3_ACCESS_KEY_ID=your-massive-access-key-id
MASSIVE_S3_SECRET_ACCESS_KEY=your-massive-secret-access-key
